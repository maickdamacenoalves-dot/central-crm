# ── Ambiente ──────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
LOG_LEVEL=debug

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_secret
POSTGRES_DB=central_crm
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql://crm:crm_secret@localhost:5433/central_crm?schema=public

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_secret

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=troque-por-um-segredo-forte-de-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Criptografia (AES-256-GCM) ───────────────────────
ENCRYPTION_KEY=troque-por-uma-chave-hex-de-64-chars

# ── Z-API ─────────────────────────────────────────────
ZAPI_INSTANCE_ID=sua-instance-id
ZAPI_INSTANCE_TOKEN=seu-token
ZAPI_BASE_URL=https://api.z-api.io/instances
ZAPI_CLIENT_TOKEN=seu-client-token

# ── Anthropic (Claude) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── VHSYS ────────────────────────────────────────────
VHSYS_TOKEN=seu-token-vhsys
VHSYS_SECRET=seu-secret-vhsys
VHSYS_BASE_URL=https://api.vhsys.com/v2

# ── Google Drive Backup ──────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# ── ClamAV ───────────────────────────────────────────
CLAMAV_ENABLED=false
